# Praxeos environment variables
# Copy to .env.local and fill in. .env.local is gitignored.

# === Public site config ===
NEXT_PUBLIC_SITE_URL="https://praxeos.org"
NEXT_PUBLIC_SITE_NAME="Praxeos"

# === Bitcoin / Halving Garden ===
# mempool.space is public; no key needed. Override endpoint for testing.
NEXT_PUBLIC_MEMPOOL_REST="https://mempool.space/api"
NEXT_PUBLIC_MEMPOOL_WS="wss://mempool.space/api/v1/ws"

# === FRED (M2 meter) ===
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=""

# === Upstash (caching) ===
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# === Supabase (newsletter + future UGC) ===
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# === Vercel Blob (tile pyramid for Halving Garden) ===
BLOB_READ_WRITE_TOKEN=""
