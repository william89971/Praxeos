{
  "name": "praxeos",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Explorable explanations for Austrian economics and praxeology.",
  "author": "William Menjivar",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "new-module": "tsx scripts/new-module.ts",
    "lint:modules": "tsx scripts/lint-modules.ts",
    "fetch:blocks": "tsx scripts/fetch-historical-blocks.ts",
    "bake-tiles": "tsx scripts/bake-tiles.ts",
    "generate:og": "tsx scripts/generate-og-batch.ts",
    "print:manifesto": "tsx scripts/print-manifesto.ts"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.4",
    "@types/mdx": "^2.0.13",
    "clsx": "^2.1.1",
    "next": "15.5.15",
    "next-themes": "^0.4.4",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "remark-footnotes": "^4.0.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.0.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@fontsource-variable/fraunces": "^5.1.1",
    "@fontsource-variable/inter": "^5.1.1",
    "@fontsource-variable/jetbrains-mono": "^5.1.2",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "@vitest/coverage-v8": "^4.1.5",
    "playwright": "^1.59.1",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
