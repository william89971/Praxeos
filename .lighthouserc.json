{
  "ci": {
    "collect": {
      "startServerCommand": "npm run start",
      "url": [
        "http://localhost:3000/",
        "http://localhost:3000/manifesto",
        "http://localhost:3000/modules",
        "http://localhost:3000/modules/halving-garden",
        "http://localhost:3000/modules/time-preference-forest",
        "http://localhost:3000/modules/calculation-problem",
        "http://localhost:3000/glossary",
        "http://localhost:3000/thinkers"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "throttlingMethod": "simulate"
      }
    },
    "assert": {
      "preset": "lighthouse:no-pwa",
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.92 }],
        "categories:accessibility": ["error", { "minScore": 1 }],
        "categories:best-practices": ["error", { "minScore": 0.95 }],
        "categories:seo": ["error", { "minScore": 1 }],
        "color-contrast": "off",
        "unused-javascript": "off",
        "uses-text-compression": "off"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
